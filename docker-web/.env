# PhotoMigrator Web Interface defaults for docker compose.
# These values work as-is for a local deployment on Linux, Windows, and macOS.

# Timezone used inside the container.
TZ=Europe/Madrid

# Container name and published host ports.
CONTAINER_NAME=photomigrator
PORT=6078
PORT_DEV=6071

# Docker image tag to pull for docker-compose.yml
IMAGE_TAG=latest-stable

# Host folders mounted into the container.
# Relative paths are resolved from the folder that contains docker-compose.yml.
# Docker will create them automatically on first start if they do not exist.
CONFIG_DIR=../config
DATA_DIR=../data
VOLUMES_DIR=../volumes

# Source tree location used only by docker-compose-dev.yml
APP_DIR=../

# Web interface runtime defaults
PHOTOMIGRATOR_WEB_DELETE_ROOTS=/app/data,/app/config,/app/volumes
PHOTOMIGRATOR_WEB_MAX_JOB_OUTPUT_LINES=100000

# Optional convenience defaults
PHOTOMIGRATOR_DEFAULT_GOOGLE_TAKEOUT_PATH=

# Optional security hardening for non-local deployments.
# If omitted, the application uses:
#   user: admin
#   password: admin123
#   secret: change-me-photomigrator-web-secret
# PHOTOMIGRATOR_WEB_SECRET=replace-with-a-long-random-secret
# PHOTOMIGRATOR_BOOTSTRAP_ADMIN_USER=admin
# PHOTOMIGRATOR_BOOTSTRAP_ADMIN_PASS=admin123

# Optional runtime overrides for cloud settings.
# Environment variables override Config.ini on every container start.
# IMMICH_URL=http://immich-server:2283
# IMMICH_API_KEY_ADMIN=your_admin_api_key
# IMMICH_API_KEY_ADMIN_FILE=/run/secrets/immich_admin_api_key
